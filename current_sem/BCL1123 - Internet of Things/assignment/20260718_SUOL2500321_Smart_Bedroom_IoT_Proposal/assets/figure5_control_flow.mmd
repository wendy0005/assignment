---
title: Priority-Based SentinelSleep Local Control Flow
config:
  theme: base
  themeVariables:
    fontFamily: Arial
    primaryColor: "#EAF4F7"
    primaryTextColor: "#17324D"
    primaryBorderColor: "#0B6E99"
    lineColor: "#0B6E99"
    fontSize: 22px
    secondaryColor: "#FFF4E4"
    tertiaryColor: "#F7FAFC"
  flowchart:
    curve: basis
    nodeSpacing: 24
    rankSpacing: 42
---
flowchart LR
    START(["Start or wake"]) --> READ["Read and validate<br/>all sensors"]
    READ --> VALID{"Readings valid?"}
    VALID -->|No| FAULT["Hold safe state<br/>Log fault and retry"]
    FAULT --> READ
    VALID -->|Yes| GAS{"Gas threshold<br/>active?"}

    GAS -->|Yes - safety priority| ALERT["Buzzer + red status<br/>Urgent MQTT alert<br/>Evacuation instruction"]
    ALERT --> READ

    GAS -->|No| NIGHT{"Night hours?"}
    NIGHT -->|Yes| NIGHTRULE["Motion + very dark<br/>Control low-output<br/>night light"]
    NIGHT -->|No| LIGHTRULE["Motion + darkness<br/>Control main light<br/>and vacancy timer"]
    NIGHTRULE --> FANRULE["Occupied + hot<br/>Control fan with<br/>hysteresis"]
    LIGHTRULE --> FANRULE
    FANRULE --> PUBLISH["Update local display<br/>Publish state<br/>Wait two seconds"]
    PUBLISH --> READ

    classDef process fill:#EAF4F7,stroke:#0B6E99,color:#17324D,stroke-width:2px;
    classDef decision fill:#FFF4E4,stroke:#B7791F,color:#17324D,stroke-width:2px;
    classDef danger fill:#FDE7E4,stroke:#B42318,color:#7A1A12,stroke-width:2px;
    classDef action fill:#E8F6EF,stroke:#14804A,color:#17324D,stroke-width:2px;
    class START,READ,PUBLISH process;
    class VALID,GAS,NIGHT decision;
    class FAULT,ALERT danger;
    class NIGHTRULE,LIGHTRULE,FANRULE action;
